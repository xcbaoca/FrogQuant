# Copy to /etc/default/frogquant and fill values

BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET_KEY=
FQ_EXEC_DRY_RUN=true

# 0 or unset => daemon mode
FQ_RUN_SECONDS=0

# Mark /health unhealthy if no tick beyond threshold
FQ_HEALTH_UNHEALTHY_AFTER_NO_TICK_SEC=15

# Server log path
FQ_LOG_PATH=/var/log/frogquant/market_logs.jsonl
